# Root .gitignore for Beat The Heat capstone project

# Environment variables
.env
.env.local
.env.*.local
**/.env

# Keep example env files
!.env.example
!**/.env.example

# Node modules & lock files
**/node_modules/
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
build/
*.tsbuildinfo
coverage/
.nyc_output/

# Python & Virtual environments
.venv/
venv/
ENV/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# Logs (except if you want to keep for reference, can be removed)
logs/
**/*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# Testing
jest.config.js
.eslintcache

# Temporary
tmp/
temp/
.venv/
*.tmp

# Database
*.db
*.sqlite
*.sqlite3

# Cache
.cache/
.turbo/
.next/

# Backend specific
backend/dist/
backend/coverage/
backend/coverage/**
backend/logs/
backend/logs/**

# Frontend specific
frontend/dist/
frontend/.env.local
frontend/dist/**
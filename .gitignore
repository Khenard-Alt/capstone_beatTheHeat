# Root .gitignore for Beat The Heat capstone project

# Environment variables
.env
.env.local
.env.*.local
**/.env

# Keep example env files
!.env.example
!**/.env.example

# Node modules
**/node_modules/
node_modules/

# Keep all docs except backend docs snapshot
!**/docs/**
/backend/docs/

# Keep all source code
!backend/src/**
!frontend/src/**
!**/src/**

# Keep all configuration files
!*.json
!*.config.js
!*.config.ts
!tsconfig*.json
!package.json
!docker-compose.yml

# Keep Docker files
!Dockerfile
!.dockerignore

# Keep linter/formatter configs
!.eslintrc*
!.prettierrc*
!.editorconfig

# Keep CI/CD configs
!.github/**
!.gitlab-ci.yml
!.circleci/**

# ==========================================
# PROJECT SPECIFIC
# ==========================================

# Uploaded files (runtime)
uploads/
**/uploads/

# Generated files

# Temporary docs scratch assets
backend/docs/text/imgAndTexts/
backend/docs/text/imgAndTexts/.md
generated/

# Backup files
*.backup
*.bak
*.old

# Database dumps (local only)
*.sql.gz
*.dump

# User data (if stored locally)
user-data/

# ==========================================
# NOTES
# ==========================================
# 
# This gitignore ensures:
# ✅ .env files are ignored (.env.example is kept)
# ✅ node_modules are ignored
# ✅ Build outputs are ignored
# ✅ All source code is tracked
# ✅ All documentation is tracked
# ✅ All database files are tracked
# ✅ All configuration files are tracked
# ✅ Logs and cache are ignored
# ✅ OS and IDE files are ignored
#
# Always commit:
# - All .md files (documentation)
# - All database/ folder contents
# - All docs/ folder contents
# - All src/ folder contents
# - Configuration files
# - .env.example (but NOT .env)
#
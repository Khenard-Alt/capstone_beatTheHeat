{
  "name": "beat-the-heat-backend",
  "version": "1.0.0",
  "description": "AI-Integrated Smart Heat Index and Real-Time Health Advisory System - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed:heat-history": "node scripts/seed-heat-history.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "heat-index",
    "health-advisory",
    "weather",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "2.99.1",
    "axios": "1.16.1",
    "bcrypt": "5.1.1",
    "cors": "2.8.6",
    "dotenv": "16.6.1",
    "express": "4.22.1",
    "express-rate-limit": "7.5.1",
    "express-validator": "7.3.1",
    "jsonwebtoken": "9.0.3",
    "morgan": "1.10.1",
    "nodemailer": "8.0.7",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cors": "2.8.19",
    "@types/express": "4.17.25",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "1.9.10",
    "@types/node": "20.19.37",
    "@types/nodemailer": "6.4.23",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "prettier": "3.8.1",
    "supabase": "2.83.0",
    "ts-jest": "29.4.6",
    "ts-node-dev": "2.0.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

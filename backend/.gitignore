# ==========================================
# NODE.JS / EXPRESS BACKEND
# ==========================================

# Environment Variables
.env
.env.local
.env.*.local

# IMPORTANT: Keep .env.example for documentation
!.env.example

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build Output
dist/
build/
*.tsbuildinfo

# Test Coverage
coverage/
.nyc_output/

# Logs
logs/
*.log

# Runtime Data
pids/
*.pid
*.seed
*.pid.lock

# Cache
.cache/
.eslintcache
.node_repl_history

# Temporary Files
*.tmp
*.temp
.tmp/
.temp/

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE / Editor Files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# ==========================================
# KEEP THESE IMPORTANT FILES
# ==========================================

# Keep all source code
!src/**

# Keep all database files
!database/**

# Keep all documentation
!docs/**

# Keep all configuration files
!*.json
!*.js
!*.ts
!tsconfig.json
!package.json
!jest.config.js

# Keep README and markdown files
!*.md
!README.md

# Keep Docker files
!Dockerfile
!.dockerignore

# Keep linter configs
!.eslintrc.json
!.prettierrc

# ==========================================
# PROJECT SPECIFIC IGNORES
# ==========================================

# Uploaded files (if any)
uploads/
public/uploads/

# Generated files
generated/

# Backup files
*.backup
*.bak

# Database dumps (if generated locally)
*.sql.gz
*.dump
# Server Configuration
PORT=5000
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# External API Keys (Weather is FREE tier, Gemini is FREE!)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here

# AI Model Provider (gemini | python | fallback)
AI_MODEL_PROVIDER=python
# Optional: override Python executable and model locations
PYTHON_EXECUTABLE=
PYTHON_MODEL_DIR=
PYTHON_AI_SCRIPT=
WEATHER_SNAPSHOT_INTERVAL_MINUTES=1

# School Coordinates (Mayamot Elementary default)
SCHOOL_LAT=14.575
SCHOOL_LON=121.025

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=noreply@beattheheat.com

# SMS Configuration (Android heartbeat SMS app recommended)
SMS_PROVIDER=android-heartbeat
ANDROID_SMS_GATEWAY_URL=http://localhost:8080/api/sms/send
ANDROID_SMS_HEARTBEAT_URL=http://localhost:8080/api/heartbeat
ANDROID_SMS_GATEWAY_API_KEY=
ANDROID_SMS_HEARTBEAT_TIMEOUT_MS=5000
HEAT_ALERT_SMS_ENABLED=true

# Optional Twilio fallback (set SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Database Configuration (if using direct PostgreSQL connection)
DATABASE_URL=postgresql://user:password@localhost:5432/beattheheat

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

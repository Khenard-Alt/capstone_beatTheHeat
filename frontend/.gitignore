.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ==========================================
# KEEP THESE IMPORTANT FILES
# ==========================================

# Keep all source code
!src/**

# Keep public assets
!public/**

# Keep all documentation
!*.md
!README.md

# Keep all configuration files
!*.json
!*.js
!*.ts
!*.tsx
!tsconfig.json
!tsconfig.*.json
!package.json
!vite.config.ts
!eslint.config.js

# Keep Docker files
!Dockerfile
!.dockerignore

# Keep linter configs
!.prettierrc

# Keep index.html
!index.html

# ==========================================
# PROJECT SPECIFIC IGNORES
# ==========================================

# Storybook
storybook-static/

# Generated files
generated/

# Backup files
*.backup
*.bak
